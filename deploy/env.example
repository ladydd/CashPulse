PORT=8080
DATABASE_PATH=/var/lib/cashpulse/cashpulse.db
TZ_NAME=Asia/Shanghai

# SMS upload only (iPhone Shortcut)
INGEST_TOKEN=change-me-long-random-ingest

# Admin Bearer token (optional if using password login)
ADMIN_TOKEN=change-me-long-random-admin

# Browser login password (recommended for public access)
ADMIN_PASSWORD=change-me-strong-password

# Cookie signing (set in production; if empty, random per process restart)
SESSION_SECRET=change-me-32bytes-hex-or-long-string

# Set true behind HTTPS
SECURE_COOKIE=true
SESSION_TTL_HOURS=168
