PORT=8080
DATABASE_PATH=./data/cashpulse.db
TZ_NAME=Asia/Shanghai

# 推荐拆分（公网）：
# 短信上报专用
INGEST_TOKEN=change-me-ingest-token
# 管理端 Bearer（可选，脚本用）
ADMIN_TOKEN=change-me-admin-token
# 浏览器登录密码（推荐）
ADMIN_PASSWORD=change-me-strong-password
SESSION_SECRET=change-me-long-random
SECURE_COOKIE=false
SESSION_TTL_HOURS=168

# 兼容旧方式（单人本地）：只设一把
# API_TOKEN=dev-token
