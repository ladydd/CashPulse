PORT=8080
DATABASE_PATH=./data/cashpulse.db
TZ_NAME=Asia/Shanghai

# Required: SMS upload (iPhone Shortcut / curl)
INGEST_TOKEN=change-me-long-random-ingest

# Required: web UI password login
ADMIN_PASSWORD=change-me-strong-password

# Optional: Bearer for scripts only (not used by the web login page)
# ADMIN_TOKEN=change-me-long-random-admin

# HTTPS production
SECURE_COOKIE=false
SESSION_TTL_HOURS=720

# Legacy (optional): if INGEST_TOKEN empty, INGEST falls back to API_TOKEN
# API_TOKEN=dev-token
